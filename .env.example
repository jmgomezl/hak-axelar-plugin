# hak-axelar-plugin environment variables
# Copy to .env and fill in your values.

# Network selection: "mainnet" or "testnet" (default: "mainnet")
AXELAR_NETWORK=testnet

# ─── Override contract addresses (optional — defaults shown) ───────────────────
# Mainnet defaults:
#   Gateway:     0xe432150cce91c13a887f7D836923d5597adD8E31
#   GasService:  0x2d5d7d31F671F86C782533cc367F14109a082712
#   ITS:         0xB5FB4BE02232B1bBA4dC8f81dc24C26980dE9e3C
# Testnet defaults (same Gateway + ITS, different GasService):
#   Gateway:     0xe432150cce91c13a887f7D836923d5597adD8E31
#   GasService:  0xbE406F0189A0B4cf3A05C286473D23791Dd44Cc6
#   ITS:         0xB5FB4BE02232B1bBA4dC8f81dc24C26980dE9e3C
#
# AXELAR_GATEWAY_ADDRESS=0xe432150cce91c13a887f7D836923d5597adD8E31
# AXELAR_GAS_SERVICE_ADDRESS=0xbE406F0189A0B4cf3A05C286473D23791Dd44Cc6
# AXELAR_ITS_ADDRESS=0xB5FB4BE02232B1bBA4dC8f81dc24C26980dE9e3C

# ─── Standard Hedera operator credentials (required by HAK) ───────────────────
HEDERA_ACCOUNT_ID=0.0.12345
HEDERA_PRIVATE_KEY=0x...yourECDSAhexPrivateKey
